# .vault-secrets.env — copy to .vault-secrets.env and fill in real values.
# .vault-secrets.env is gitignored. NEVER commit the filled-in version.
#
# Usage: bash scripts/vault-seed.sh
#   or:  just vault-seed
#
# After filling in, run vault-seed after every cluster rebuild (Vault PVC is
# lost when kind cluster is deleted — all secrets must be re-seeded).

# Vault root token from: just vault-init output
VAULT_ROOT_TOKEN=hvs.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Dex / GitHub OAuth App ────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Homepage URL:             http://dex.homelab.local
#   Authorization callback:   http://dex.homelab.local/callback
DEX_GITHUB_CLIENT_ID=Ov23liXXXXXXXXXXXXXX
DEX_GITHUB_CLIENT_SECRET=

# ── Shared OIDC client secrets ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
DEX_ARGOCD_CLIENT_SECRET=
DEX_VAULT_CLIENT_SECRET=
